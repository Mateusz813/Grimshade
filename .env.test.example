# E2E test accounts + admin key template — commit this file, NOT `.env.test`.
#
# Copy to `.env.test` and fill in real values before running
# `npm run test:e2e`. The real `.env.test` is gitignored.
#
# Konta primary/secondary musza juz istniec w Supabase Auth schema
# do ktorej wskazuje VITE_SUPABASE_URL — tworzy je wlasciciel rzecznie
# (raz, na zawsze), testy ich nie kasuja.
#
# Konta @grimshade-test.local tworzone w testach rejestracji sa
# kasowane przez `tests/e2e/fixtures/cleanup.ts` po kazdym tescie —
# do tego potrzeba SUPABASE_SERVICE_ROLE_KEY.

# Primary — single-user scenarios (login, character flow, combat solo)
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# Secondary — multi-context scenarios (party, Realtime, chat, PM)
E2E_USER2_EMAIL=
E2E_USER2_PASSWORD=

# Admin — BACKLOG 15.6 admin panel full smoke (9 tabs).
# Must match an entry in ADMIN_EMAILS set (src/components/ui/AdminPanel/AdminPanel.tsx).
# Convention: use `e2e-admin@grimshade-test.local` (fake TLD, can't deliver mail).
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# Supabase service_role JWT — GOD MODE, bypassuje RLS. Uzywany TYLKO
# przez tests/e2e/fixtures/cleanup.ts. NIGDY do kodu klienta.
# Dashboard -> Settings -> API -> sekcja "Legacy" -> service_role
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project URL — wpisz to samo co siedzi w .env.local
VITE_SUPABASE_URL=
